# Environment Variables
# Copy this file to .env.local and fill in your values

# --- Gemini API (for local dev - client-side fallback) ---
# Get your key at https://aistudio.google.com/apikey
# In production (Vercel), set GEMINI_API_KEY as an environment variable
# and it will be used server-side via the /api/gemini proxy.

# --- Supabase ---
# Create a project at https://supabase.com
# Find these values in Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
